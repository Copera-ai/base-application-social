{
  "name": "web",
  "author": "Christian Curi <c.christiancuri@gmail.com>",
  "version": "1.0.0",
  "description": "Base Application Web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 8087",
    "start": "vite preview",
    "build": "tsc && vite build",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:print": "npx eslint --print-config eslint.config.mjs > eslint-show-config.json",
    "fm:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "fix:all": "npm run lint:fix && npm run fm:fix",
    "clean": "rm -rf node_modules .next out dist build",
    "re:dev": "pnpm run clean && pnpm run install && pnpm run dev",
    "re:build": "pnpm run clean && pnpm run install && pnpm run build",
    "re:build-npm": "npm run clean && npm install && npm run build",
    "tsc:dev": "pnpm run dev & pnpm run tsc:watch",
    "tsc:watch": "tsc --noEmit --watch",
    "tsc:print": "npx tsc --showConfig",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@iconify/react": "^5.2.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "catalog:devDeps",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "motion": "^12.23.12",
    "notistack": "^3.0.0",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-hook-form": "^7.55.0",
    "react-router": "^7.4.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.13",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:devDeps",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react-swc": "catalog:devDeps",
    "prettier": "^3.5.3",
    "typescript": "catalog:devDeps",
    "vite": "catalog:devDeps",
    "vite-plugin-checker": "catalog:devDeps"
  }
}
